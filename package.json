{
  "name": "isfree.se",
  "version": "2.0.0",
  "description": "isfree.se",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy": "$npm_execpath run build && wrangler pages deploy dist",
