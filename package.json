{
  "name": "isfree.se",
  "version": "2.0.0",
  "description": "isfree.se",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "deploy-staging": "wrangler deploy --env staging --minify",
    "lint": "npx eslint",
    "prettier": "npx prettier . --check",
    "test:react": "vitest -c vitest.react.config.ts --run",
    "test:worker": "vitest -c vitest.worker.config.ts --run",
    "test": "npm run test:react && npm run test:worker",
    "typecheck": "npx tsc --build --noEmit"
  },
  "dependencies": {
    "hono": "^4.12.18",
    "idna-uts46-hx": "^6.1.7",
    "luxon": "^3.7.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.3",
    "@cloudflare/workers-types": "^4.20260511.1",
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/luxon": "^3.7.1",
    "@types/punycode": "^2.1.4",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-testing-library": "^7.15.4",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "prettier": "3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
