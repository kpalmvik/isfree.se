  },
  "dependencies": {
    "hono": "^4.0.1",
    "se-free": "1.0.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240129.0",
    "@eslint/js": "^8.56.0",
    "@hono/vite-cloudflare-pages": "^0.2.4",
